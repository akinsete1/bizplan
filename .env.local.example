# BizPlan Nigeria — Environment Variables
# Copy this file to .env.local and fill in your real values

# ─────────────────────────────────────────────
# SUPABASE
# Found at: https://app.supabase.com → Your Project → Settings → API
# ─────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─────────────────────────────────────────────
# PAYSTACK
# Found at: https://dashboard.paystack.com → Settings → API Keys & Webhooks
# Use TEST keys during development, LIVE keys in production
# ─────────────────────────────────────────────
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=pk_test_your-public-key-here
PAYSTACK_SECRET_KEY=sk_test_your-secret-key-here

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3002
NEXT_PUBLIC_PAYSTACK_PRO_PLAN_ID=PLN_xxxxxxxx
NEXT_PUBLIC_PAYSTACK_BUSINESS_PLAN_ID=PLN_xxxxxxxx
